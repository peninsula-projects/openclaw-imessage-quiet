{
  "id": "imessage-quiet",
  "kind": "channel",
  "channels": ["imessage-quiet"],
  "name": "iMessage (Quiet)",
  "description": "Mention-gated iMessage channel plugin — speak when spoken to",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "imessage-quiet": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Enable or disable the imessage-quiet channel",
            "default": true
          },
          "accounts": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "name": { "type": "string" },
                "cliPath": {
                  "type": "string",
                  "description": "Path to the imsg CLI binary",
                  "default": "imsg"
                },
                "dbPath": {
                  "type": "string",
                  "description": "Path to iMessage chat.db (optional override)"
                },
                "mentionPatterns": {
                  "type": "array",
                  "items": { "type": "string", "maxLength": 50 },
                  "description": "Patterns to detect @mentions (e.g. ['@millbot'])"
                }
              }
            },
            "description": "Named accounts (use 'default' for single-account setup)"
          },
          "cliPath": { "type": "string" },
          "dbPath": { "type": "string" },
          "mentionPatterns": { "type": "array", "items": { "type": "string", "maxLength": 50 } }
        }
      }
    }
  }
}
